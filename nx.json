{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "executor": "@nx/js:tsc",
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"]
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "vitest run",
        "cwd": "{projectRoot}"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "vitest run --coverage.enabled",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "eslint .",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "tsc",
        "cwd": "{projectRoot}"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write .",
        "cwd": "{projectRoot}"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "prettier --check .",
        "cwd": "{projectRoot}"
      }
    },
    "docs": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/docs"]
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish"
    }
  },
  "analytics": false,
  "release": {
    "version": {
      "preVersionCommand": "npx nx run-many -t build"
    }
  }
}
