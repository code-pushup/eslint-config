{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "parallel": 3,
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.base.json",
      { "runtime": "node -v" },
      { "runtime": "npm -v" }
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.[jt]s",
      "!{projectRoot}/eslint.config.js",
      "!{projectRoot}/vitest.config.[jt]s",
      "!{projectRoot}/tsconfig.spec.json"
    ],
    "lint-eslint-inputs": [{ "externalDependencies": ["eslint"] }],
    "test-vitest-inputs": [
      "{workspaceRoot}/vitest.config.ts",
      { "externalDependencies": ["vitest"] }
    ],
    "typecheck-typescript-inputs": [
      "{workspaceRoot}/tsconfig.base.json",
      { "externalDependencies": ["typescript"] }
    ]
  },
  "targetDefaults": {
    "build": {
      "executor": "@nx/js:tsc",
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^default", "test-vitest-inputs"],
      "options": {
        "command": "vitest run",
        "cwd": "{projectRoot}"
      }
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^default", "test-vitest-inputs"],
      "options": {
        "command": "vitest run --coverage.enabled",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^default", "lint-eslint-inputs"],
      "options": {
        "command": "eslint .",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^default", "typecheck-typescript-inputs"],
      "options": {
        "command": "tsc",
        "cwd": "{projectRoot}"
      }
    },
    "docs": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/docs"]
    },
    "nx-release-publish": {
      "dependsOn": ["build"],
      "executor": "@nx/js:release-publish"
    }
  },
  "analytics": false,
  "release": {
    "projects": ["packages/*"],
    "projectsRelationship": "fixed",
    "changelog": {
      "automaticFromRef": true,
      "projectChangelogs": false,
      "workspaceChangelog": {
        "createRelease": "github"
      }
    },
    "git": {
      "commit": true,
      "push": true,
      "pushRemote": "origin",
      "tag": true,
      "commitMessage": "release: {version}"
    },
    "version": {
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk"
    },
    "releaseTagPattern": "v{version}"
  }
}
